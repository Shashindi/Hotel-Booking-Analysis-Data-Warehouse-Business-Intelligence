                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    TRY_CAST(review_id AS INT) AS review_id,
    TRY_CAST(user_id AS INT) AS user_id,
    TRY_CAST(hotel_id AS INT) AS hotel_id,
    CAST(CONVERT(VARCHAR(8), TRY_CAST(review_date AS DATE), 112) AS INT) AS date_key,
    score_overall,
    score_cleanliness,
    score_comfort,
    score_facilities,
    score_location,
    score_staff,
    score_value_for_money
FROM Staging_Reviews
WHERE TRY_CAST(review_id AS INT) IS NOT NULL
  AND TRY_CAST(user_id AS INT) IS NOT NULL
  AND TRY_CAST(hotel_id AS INT) IS NOT NULL
  AND TRY_CAST(review_date AS DATE) IS NOT NULL
  AND TRY_CAST(review_date AS DATE) &lt;&gt; '1900-01-01';</property>
